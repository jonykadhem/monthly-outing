<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authentication App</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    
</head>
<body>
    <nav class="site-nav">
        <a class="site-nav-brand" href="/">Authentication App</a>

        <div class="site-nav-links">
            <a class="site-nav-link" href="/">Home</a>
            <a class="site-nav-link" href="/suggestions">Restaurants</a>
            <a class="site-nav-link" href="/reviews">Reviews</a>
            
            <% if (user) { %>
                <a class="site-nav-link" href="/dashboard">Dashboard</a>
                <a class="site-nav-link" href="/restaurant/new">Add Suggestion</a>

                <form
                    class="site-nav-form"
                    action="/auth/sign-out?_method=DELETE"
                    method="POST"
                >
                    <button class="site-nav-button" type="submit">
                        Sign Out
                    </button>
                </form>
            <% } else  { %>
                <a class="site-nav-link" href="/auth/sign-up">Sign Up</a>
                <a class="site-nav-link" href="/auth/sign-in">Sign In</a>
            <% } %>
            <% if (user && user.role === 'admin') { %>
                <a  href="/admin">Admin Page</a>
            <% } %>
        </div>
    </nav>
