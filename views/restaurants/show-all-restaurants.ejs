<%- include("../partials/nav.ejs") %>

<h1>All Suggseted Restaurants</h1>

<% allSuggestions.forEach(element => { %>
 <div class="card" style="width: 18rem;">
  <img src="../../assits/wokman.png" class="card-img-top" alt="...">
  <div class="card-body">
    <h5 class="card-title"><%= element.name %></h5>
    <p class="card-text"><%= element.details %></p>
    <a href="<%= "/restaurant/" + element.id %>" class="btn btn-primary">View Details</a>
  </div>
</div>

<% }) %>

</body>
</html>