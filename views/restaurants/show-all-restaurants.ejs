<%- include("../partials/head", {
    title: "Suggested Restaurants",
    css: "suggestions"
}) %>



<%- include("../partials/nav.ejs") %>

<div class="restaurants-page">

    <h1 class="page-title">
        All Suggested Restaurants
    </h1>

    <div class="restaurant-grid">

        <% allSuggestions.forEach(element => { %>

            <div class="restaurant-card">

                <img src="<%= element.image || '/assets/default-restaurant.jpg' %>" alt="<%= element.name %>">

                <div class="restaurant-info">

                    <h3><%= element.name %></h3>

                    <p>
                        <%= element.details %>
                    </p>

                    <a
                        href="/restaurant/<%= element._id %>"
                        class="details-btn"
                    >
                        View Details
                    </a>

                </div>

            </div>

        <% }) %>

    </div>

</div>

</body>
</html>