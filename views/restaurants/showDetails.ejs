<%- include("../partials/head", {
    title: "Restaurant Details",
    css: "restaurant-details"
}) %>


<%- include("../partials/nav.ejs") %>

<%
function toStars(num){
    const rounded = Math.round(num)
    return '★'.repeat(rounded) + '☆'.repeat(5 - rounded)
}
%>
<div class="restaurant-container">

    <div class="restaurant-header">

        <h1><%= foundRestaurant.name %></h1>

        <p class="restaurant-description">
            <%= foundRestaurant.details %>
        </p>

        <p class="restaurant-recommendation">
            <%= foundRestaurant.recommendation %>
        </p>

        <div class="restaurant-links">
            <a href="<%= foundRestaurant.location %>" class="location-btn">
                📍 Location
            </a>

            <a href="<%= foundRestaurant.instagram %>" class="instagram-btn">
                📸 Instagram
            </a>
        </div>

    </div>

    <% if(categoryAverages){ %>

    <div class="reviews-section">

        <% reviews.forEach(element=>{ %>

        <div class="review-card">

            <div class="ratings">

                <p><strong>Price</strong> <%= toStars(element.price) %></p>

                <p><strong>Taste</strong> <%= toStars(element.taste) %></p>

                <p><strong>Service</strong> <%= toStars(element.service) %></p>

                <p><strong>Quantity</strong> <%= toStars(element.quantity) %></p>

            </div>

            <p class="comment">
                "<%= element.comment %>"
            </p>

            <% if(user && (user.role==="admin" || user.role==="reviewer")){ %>

            <form action="/restaurant/<%= foundRestaurant._id %>/review/<%= element._id %>/edit" method="GET">

                <button class="edit-review-btn">
                    Edit Review
                </button>

            </form>

            <% } %>

        </div>

        <% }) %>

    </div>

    <div class="average-rating">

        <h3>
            Overall Rating:
            <span><%= toStars(overallAverage) %></span>

            (<%= overallAverage %>/5,
            <%= reviews.length %> Reviews)
        </h3>

    </div>

    <% } else { %>

    <p class="no-review">
        No reviews yet.
    </p>

    <% } %>

    <div class="action-buttons">

        <a href="/suggestions" class="back-btn">
            Back
        </a>

        <% if(foundRestaurant.owner._id.equals(user.id) || user.role==="admin"){ %>

        <form action="/restaurant/<%= foundRestaurant._id %>?_method=DELETE" method="POST">
            <button class="delete-btn">
                Delete
            </button>
        </form>

        <form action="/restaurant/<%= foundRestaurant._id %>/edit" method="GET">
            <button class="edit-btn">
                Edit
            </button>
        </form>

        <% } %>

        <% if(user && (user.role==="admin" || user.role==="reviewer")){ %>

        <form action="/restaurant/<%= foundRestaurant._id %>/review" method="GET">
            <button class="review-btn">
                Review Restaurant
            </button>
        </form>

        <% } %>

    </div>

</div>


</body>
</html>

