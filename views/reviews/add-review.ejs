<%- include("../partials/head", {
    title: "Add Review",
    css: "review-form"
}) %>

<%- include("../partials/nav.ejs") %>

<div class="review-container">

    <div class="review-card">

        <h1>Review Restaurant</h1>

        <h2><%= foundRestaurant.name %></h2>

        <div class="restaurant-info">

            <p><strong>📍 Location:</strong> <%= foundRestaurant.location %></p>

            <p><strong>📸 Instagram:</strong> <%= foundRestaurant.instagram %></p>

            <p><strong>🍽 Recommended:</strong> <%= foundRestaurant.recommendation %></p>

            <p><strong>📝 Details:</strong> <%= foundRestaurant.details %></p>

        </div>

        <form action="/restaurant/<%= foundRestaurant._id %>/review?_method=PUT" method="POST">

            <div class="ratings-grid">

                <div class="form-group">
                    <label for="price">Price (1-5)</label>
                    <input
                        type="number"
                        id="price"
                        name="price"
                        min="1"
                        max="5"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="taste">Taste (1-5)</label>
                    <input
                        type="number"
                        id="taste"
                        name="taste"
                        min="1"
                        max="5"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="service">Service (1-5)</label>
                    <input
                        type="number"
                        id="service"
                        name="service"
                        min="1"
                        max="5"
                        required
                    >
                </div>

                <div class="form-group">
                    <label for="quantity">Quantity (1-5)</label>
                    <input
                        type="number"
                        id="quantity"
                        name="quantity"
                        min="1"
                        max="5"
                        required
                    >
                </div>

            </div>

            <div class="form-group">

                <label for="comment">Your Review</label>

                <textarea
                    id="comment"
                    name="comment"
                    rows="5"
                    placeholder="Tell others about your experience..."
                    required
                ></textarea>

            </div>

            <button class="submit-btn" type="submit">

                Submit Review

            </button>

        </form>

    </div>

</div>

</body>
</html>