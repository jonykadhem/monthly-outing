<%- include("../partials/head", {
    title: "Edit Review",
    css: "edit-review"
}) %>

<%- include("../partials/nav.ejs") %>

<div class="edit-review-container">

    <div class="review-card">

        <h1>Edit Review</h1>

        <h2><%= foundRestaurant.name %></h2>

        <div class="restaurant-info">

            <p><strong>📍 Location:</strong> <%= foundRestaurant.location %></p>

            <p><strong>📸 Instagram:</strong> <%= foundRestaurant.instagram %></p>

            <p><strong>🍽 Recommendation:</strong> <%= foundRestaurant.recommendation %></p>

            <p><strong>📝 Details:</strong> <%= foundRestaurant.details %></p>

        </div>

        <form action="/restaurant/<%= foundRestaurant._id %>/review/<%= foundReview._id %>?_method=PUT" method="POST">

            <div class="ratings-grid">

                <div class="form-group">
                    <label>Price</label>
                    <input type="number" name="price" min="1" max="5" value="<%= foundReview.price %>" required>
                </div>

                <div class="form-group">
                    <label>Taste</label>
                    <input type="number" name="taste" min="1" max="5" value="<%= foundReview.taste %>" required>
                </div>

                <div class="form-group">
                    <label>Service</label>
                    <input type="number" name="service" min="1" max="5" value="<%= foundReview.service %>" required>
                </div>

                <div class="form-group">
                    <label>Quantity</label>
                    <input type="number" name="quantity" min="1" max="5" value="<%= foundReview.quantity %>" required>
                </div>

            </div>

            <div class="form-group">

                <label>Your Review</label>

                <textarea
                    name="comment"
                    rows="5"
                    required><%= foundReview.comment %></textarea>

            </div>

            <button class="submit-btn" type="submit">

                Save Changes

            </button>

        </form>

    </div>

</div>

